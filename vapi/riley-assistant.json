{
  "name": "Riley",
  "firstMessage": "Thank you for calling Smile Dental Clinic! This is Riley. Are you calling to book an appointment, or do you have a question about our services?",
  "model": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.5,
    "messages": [
      {
        "role": "system",
        "content": "You are a bilingual dental receptionist (English and Chinese).\n\nYour job:\n- Answer phone calls\n- Help patients book appointments\n- Ask for name and phone number\n\nRules:\n- If the caller speaks Chinese, reply in Chinese\n- If the caller speaks English, reply in English\n- Keep answers short (1-2 sentences)\n- Be friendly and natural\n\nClinic Info:\n- Name: Smile Dental Clinic\n- Address: 123 Main Street, Newmarket, ON L3Y 4Z1\n- Phone: (905) 555-0123\n- Hours: Mon–Fri 8am–6pm, Sat 9am–2pm, Sun Closed\n- Dentists: Dr. Sarah Chen, Dr. Michael Park, Dr. Priya Sharma\n- Services: Checkups, Cleanings, Whitening, Fillings, Crowns, Root Canals, Implants, Invisalign, Pediatric, Emergency\n\nCall flow:\n1. Greet the caller\n2. Ask what they need (book, reschedule, cancel, question)\n3. For booking: ask service, dentist preference, name, phone number, preferred date\n4. Use check_availability to find open slots\n5. Confirm the booking with book_appointment\n6. Send confirmation with send_confirmation_email\n7. Thank them and say goodbye"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "check_availability",
          "description": "Check available appointment slots for a specific date and optionally a specific dentist. Always call this before offering times to a patient.",
          "parameters": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "description": "Date to check in YYYY-MM-DD format"
              },
              "dentist": {
                "type": "string",
                "description": "Dentist name. If not specified, check all dentists.",
                "enum": [
                  "Dr. Sarah Chen",
                  "Dr. Michael Park",
                  "Dr. Priya Sharma"
                ]
              },
              "service": {
                "type": "string",
                "description": "Type of dental service requested"
              }
            },
            "required": [
              "date"
            ]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "book_appointment",
          "description": "Book a confirmed appointment. Only call this after the patient has confirmed all details.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": {
                "type": "string",
                "description": "Patient's full name"
              },
              "patient_phone": {
                "type": "string",
                "description": "Patient's phone number"
              },
              "patient_email": {
                "type": "string",
                "description": "Patient's email address for confirmation"
              },
              "date": {
                "type": "string",
                "description": "Appointment date in YYYY-MM-DD format"
              },
              "time": {
                "type": "string",
                "description": "Appointment time in HH:MM format (24h)"
              },
              "dentist": {
                "type": "string",
                "description": "Dentist name",
                "enum": [
                  "Dr. Sarah Chen",
                  "Dr. Michael Park",
                  "Dr. Priya Sharma"
                ]
              },
              "service": {
                "type": "string",
                "description": "Type of dental service"
              },
              "is_new_patient": {
                "type": "boolean",
                "description": "Whether this is a new patient"
              },
              "notes": {
                "type": "string",
                "description": "Any special notes or concerns"
              }
            },
            "required": [
              "patient_name",
              "patient_phone",
              "date",
              "time",
              "dentist",
              "service"
            ]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "cancel_appointment",
          "description": "Cancel an existing appointment.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": {
                "type": "string",
                "description": "Patient's full name"
              },
              "date": {
                "type": "string",
                "description": "Date of appointment to cancel in YYYY-MM-DD format"
              },
              "appointment_id": {
                "type": "string",
                "description": "Appointment ID if known"
              }
            },
            "required": [
              "patient_name"
            ]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "send_confirmation_email",
          "description": "Send a booking confirmation email to the patient after an appointment is booked or rescheduled.",
          "parameters": {
            "type": "object",
            "properties": {
              "patient_name": {
                "type": "string",
                "description": "Patient's full name"
              },
              "patient_email": {
                "type": "string",
                "description": "Patient's email address"
              },
              "date": {
                "type": "string",
                "description": "Appointment date in YYYY-MM-DD format"
              },
              "time": {
                "type": "string",
                "description": "Appointment time in HH:MM format"
              },
              "dentist": {
                "type": "string",
                "description": "Dentist name"
              },
              "service": {
                "type": "string",
                "description": "Type of dental service"
              }
            },
            "required": [
              "patient_name",
              "patient_email",
              "date",
              "time",
              "dentist",
              "service"
            ]
          }
        }
      }
    ]
  },
  "voice": {
    "provider": "vapi",
    "voiceId": "Elliot"
  },
  "transcriber": {
    "provider": "deepgram",
    "model": "nova-3",
    "language": "multi",
    "endpointing": 150
  },
  "voicemailMessage": "Hello, this is Riley from Smile Dental Clinic. We're calling about your appointment. Please call us back at (905) 555-0123 at your earliest convenience.",
  "endCallMessage": "Thank you for calling Smile Dental Clinic! We look forward to seeing you. Have a great day!",
  "endCallPhrases": [
    "goodbye",
    "bye",
    "talk to you soon",
    "thanks bye",
    "that's all"
  ],
  "startSpeakingPlan": {
    "waitSeconds": 0.4,
    "smartEndpointingEnabled": "livekit"
  },
  "backgroundDenoisingEnabled": true,
  "backchannelingEnabled": false,
  "hipaaEnabled": false,
  "clientMessages": [
    "transcript",
    "hang",
    "function-call",
    "speech-update",
    "metadata",
    "transfer-update",
    "conversation-update"
  ],
  "serverMessages": [
    "end-of-call-report",
    "status-update",
    "hang",
    "function-call"
  ]
}