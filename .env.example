# Reception stack — environment variables

# Vapi
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
# Required to push/link: UUID from `vapi assistant list` (your pre-existing agent)
VAPI_ASSISTANT_ID=
# scripts/vapi/connect-supabase-vapi.sh: full = replace assistant from riley-assistant.json; server = only set serverUrl
# CONNECT_ASSISTANT_MODE=server
# VAPI_EDGE_CREDENTIAL_ID=
# TOOL_API_KEY=   # only if scripts/vapi/sync-tool-auth.sh needs to PATCH tools (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional public tunnel base, e.g. https://your-machine.your-tailnet.ts.net
# Vapi serverUrl should be: ${PUBLIC_BASE_URL}/functions/v1/webhook
PUBLIC_BASE_URL=
# Optional explicit health base override
VAPI_HEALTH_BASE=

# Supabase project reference used by ./scripts/vapi/connect-supabase-vapi.sh
# Format: abcdefghijklmnopqrstu
SUPABASE_PROJECT_REF=
