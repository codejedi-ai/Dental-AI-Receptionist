# Reception stack — environment variables

# Vapi
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
TOOL_API_KEY=
# Set to 1 for verbose /api/tools request+response logs (URL, headers, body, timing). Unset in production.
VAPI_TOOLS_DEBUG=

# Go tool server — run only on your machine (./run-vapi-local.sh). Loopback-only bind:
HTTP_LISTEN_ADDR=127.0.0.1:8080
PUBLIC_BASE_URL=
VAPI_HEALTH_BASE=
