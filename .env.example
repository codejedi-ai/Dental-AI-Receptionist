# ─────────────────────────────────────────────────────────────
# Dental AI Reception — Environment Variables
#
# Databases (PostgreSQL + MongoDB) are fully self-contained
# in Docker containers — no configuration needed.
# ─────────────────────────────────────────────────────────────

# Vapi API (required)
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Email — SMTP (required for sending confirmations)
SMTP_EMAIL=
SMTP_PASSWORD=

# Google Calendar — optional (leave blank to skip calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Tailscale (required for remote access)
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=dental-ai

# Clinic name (shown in the frontend)
CLINIC_NAME=Dental Clinic
