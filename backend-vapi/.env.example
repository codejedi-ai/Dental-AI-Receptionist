# Vapi API Keys (from https://dashboard.vapi.ai)
VAPI_API_KEY=your_private_api_key_here
VAPI_PUBLIC_KEY=your_public_api_key_here

# Webhook server
PORT=3000
WEBHOOK_URL=https://your-domain.com/webhook

# Optional: Bring your own provider keys
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# DEEPGRAM_API_KEY=...
