# Vapi API Keys (from https://dashboard.vapi.ai)
VAPI_API_KEY=your_private_api_key_here
VAPI_PUBLIC_KEY=your_public_api_key_here

# Webhook server
PORT=3000
WEBHOOK_URL=

# Set this after running: npm run setup
VAPI_ASSISTANT_ID=

# Tailscale Funnel — generates the public HTTPS tunnel (replaces ngrok)
# Get an auth key from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=tskey-auth-...
TAILSCALE_HOSTNAME=smiledental-webhook

# Optional: Bring your own provider keys
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# DEEPGRAM_API_KEY=...
